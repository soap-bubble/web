    "@rooks/use-raf": "^4.11.2",
    "@soapbubble/morpheus-client": "link:../morpheus",
    "@tweenjs/tween.js": "^18.6.4",
    "@types/three": "^0.182.0",
    "axios": "^1.7.7",
    "bluebird": "^3.7.2",
    "browser-bunyan": "^1.6.4",
    "firebase": "^8.6.3",
    "firebase-admin": "^10.3.0",
    "generic-pool": "^3.7.8",
    "immutable": "^4.3.6",
    "keycode": "^2.2.0",
