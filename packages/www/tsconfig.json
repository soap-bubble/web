{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "esnext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "@soapbubble/morpheus-client": [
        "../morpheus/client/js/index.ts"
      ],
      "@soapbubble/morpheus-client/*": [
        "../morpheus/client/js/*"
      ],
      "morpheus": [
        "../morpheus/client/js/morpheus/index.ts"
      ],
      "morpheus/*": [
        "../morpheus/client/js/morpheus/*"
      ],
      "*": [
        "src/*"
      ]
    },
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "downlevelIteration": true,
    "jsx": "react-jsx",
    "incremental": true,
    "composite": true,
    "tsBuildInfoFile": "./tsconfig.tsbuildinfo",
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
  ],
  "exclude": [
    "node_modules"
  ],
  "references": [
    {
      "path": "../morpheus"
    }
  ]
}
