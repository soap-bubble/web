{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "allowJs": true,
    "checkJs": false,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "baseUrl": "./client/js",
    "rootDir": "./client/js",
    "paths": {
      "morpheus/*": ["morpheus/*"],
      "service/*": ["service/*"],
      "store/*": ["store/*"],
      "utils/*": ["utils/*"]
    }
  },
  "include": ["client/js"]
}
