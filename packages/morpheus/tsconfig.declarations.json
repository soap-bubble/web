{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "./dist",
    "rootDir": "./client/js",
    "allowJs": false,
    "checkJs": false,
    "noEmit": false
  },
  "include": [
    "client/js/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}

