{
  "name": "@soapbubble/morpheus-client",
  "version": "1.13.0",
  "description": "Morpheus runtime engine rebuilt as a TypeScript-first ESM package.",
  "private": true,
  "type": "module",
  "browserslist": "last 2 Chrome versions",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./types/index.d.ts",
  "scripts": {
    "dev": "node ./scripts/clean-types.mjs && node ../../node_modules/typescript/bin/tsc -b tsconfig.types.json --watch --preserveWatchOutput",
    "build": "node ./scripts/clean-dist.mjs && node ./scripts/build-esm.mjs && node ../../node_modules/typescript/bin/tsc -b tsconfig.declarations.json && node ./scripts/copy-static.mjs",
    "typecheck": "node ./scripts/clean-types.mjs && node ../../node_modules/typescript/bin/tsc -b tsconfig.types.json",
    "lint": "eslint client config server",
    "test": "jest client",
    "test:watch": "cross-env NODE_ENV=development jest client --watch"
  },
  "license": "ISC",
  "jest": {
    "collectCoverageFrom": [
      "client/**/*.{ts,tsx,js,jsx}"
    ],
    "setupFiles": [
      "<rootDir>/config/polyfills.js"
    ],
    "watchPathIgnorePatterns": [
      "<rootDir>//public"
    ],
    "testEnvironment": "node",
    "testURL": "http://localhost",
    "transform": {
      "^.+\\.((j|t)sx?)$": "<rootDir>/jestBabelProcessor.js",
      "^.+\\.css$": "<rootDir>/config/jest/cssTransform.js",
      "^(?!.*\\.(js|jsx|css|json)$)": "<rootDir>/config/jest/fileTransform.js"
    },
    "transformIgnorePatterns": [
      "[/\\\\]node_modules[/\\\\].+\\.(js|jsx)$"
    ]
  },
  "peerDependencies": {
    "@react-three/fiber": ">=9.0.0",
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0",
    "react-redux": ">=9.0.0",
    "redux": ">=4.2.0",
    "redux-observable": ">=2.0.0",
    "redux-thunk": ">=2.4.0",
    "reselect": ">=4.1.0",
    "rxjs": ">=7.0.0",
    "three": ">=0.124.0"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.11.2",
    "@rooks/use-raf": "^4.11.2",
    "@tweenjs/tween.js": "^18.6.4",
    "axios": "^1.7.7",
    "bluebird": "^3.7.2",
    "browser-bunyan": "^1.6.4",
    "classnames": "^2.5.1",
    "events": "^3.3.0",
    "generic-pool": "^3.9.0",
    "immutable": "^4.3.6",
    "local-storage": "^2.0.0",
    "lodash": "^4.17.21",
    "promise-queue": "^2.2.5",
    "prop-types": "^15.8.1",
    "query-string": "^8.2.0",
    "raf": "^3.4.1",
    "react-bootstrap": "^2.10.3",
    "redux-logger": "^3.0.6",
    "rxjs-compat": "^6.6.7",
    "rxjs-hooks": "^0.8.0-alpha.0",
    "ua-parser-js": "^1.0.37",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@react-three/fiber": "^9.4.2",
    "@types/lodash": "^4.14.202",
    "@types/minimatch": "^5.1.2",
    "@types/node": "^20.14.9",
    "@types/prop-types": "^15.7.12",
    "@types/query-string": "^6.3.0",
    "@types/react": "^19.2.7",
    "@types/react-bootstrap": "^0.32.37",
    "@types/react-dom": "^19.2.3",
    "@types/react-redux": "^7.1.33",
    "@types/uuid": "^9.0.8",
    "esbuild": "^0.23.0",
    "fast-glob": "^3.3.2",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-redux": "^9.2.0",
    "redux": "^5.0.1",
    "redux-observable": "^3.0.0-rc.3",
    "redux-thunk": "^2.4.2",
    "reselect": "^4.1.8",
    "rxjs": "^7.8.2",
    "three": "^0.182.0",
    "typescript": "^5.6.3"
  }
}
