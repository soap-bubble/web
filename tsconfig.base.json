{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "module": "Preserve",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "baseUrl": ".",
    "paths": {
      "@soapbubble/morpheus-client": [
        "packages/morpheus/client/js/morpheus/index.ts"
      ],
      "@soapbubble/morpheus-client/*": [
        "packages/morpheus/client/js/morpheus/*"
      ],
      "morpheus": [
        "packages/morpheus/client/js/morpheus/index.ts"
      ],
      "morpheus/*": [
        "packages/morpheus/client/js/morpheus/*"
      ]
    }
  }
}

