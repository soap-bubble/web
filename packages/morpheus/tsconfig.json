{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "incremental": true,
    "rootDir": "./client/js",
    "outDir": "./dist",
    "baseUrl": "./client/js",
    "allowJs": true,
    "checkJs": false,
    "emitDeclarationOnly": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "tsBuildInfoFile": "./dist/tsconfig.tsbuildinfo",
    "paths": {
      "service/*": [
        "service/*"
      ],
      "store/*": [
        "store/*"
      ],
      "utils/*": [
        "utils/*"
      ]
    }
  },
  "include": [
    "client/js"
  ]
}
